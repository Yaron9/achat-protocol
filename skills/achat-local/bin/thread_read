#!/usr/bin/env node
'use strict';

const fs = require('fs');
const path = require('path');
const os = require('os');
const { THREADS_DIR } = require(path.join(__dirname, '..', 'lib', 'platform'));

// Usage: thread_read <thread_id> [--json]
const args = process.argv.slice(2);
if (args.length < 1) {
  console.error('Usage: thread_read <thread_id> [--json]');
  process.exit(1);
}

const threadId = args[0];
const jsonMode = args.includes('--json');

const threadsDir = THREADS_DIR;
const filePath = path.join(threadsDir, `${threadId}.jsonl`);

if (!fs.existsSync(filePath)) {
  console.error(`ERROR: Thread not found: ${threadId}`);
  process.exit(1);
}

const raw = fs.readFileSync(filePath, 'utf8').trim();
const lines = raw.split('\n').filter(l => l.trim());

if (jsonMode) {
  console.log(raw);
  process.exit(0);
}

// Human-readable
const objects = lines.map(l => {
  try { return JSON.parse(l); } catch (e) { return null; }
}).filter(Boolean);

const header = objects[0] || {};
const messages = objects.slice(1);

const participants = Array.isArray(header.participants) ? header.participants.join(', ') : '';
console.log(`=== Thread: ${threadId} ===`);
console.log(`Subject: ${header.subject || ''} | Participants: ${participants}`);
console.log('');

for (const msg of messages) {
  const text = Array.isArray(msg.parts) && msg.parts[0] ? msg.parts[0].text : '';
  const intent = (msg.metadata && msg.metadata.intent) || 'SAY';
  console.log(`[${msg.seq}] ${msg.from} → ${msg.to}  (${intent}) ${msg.ts}`);
  console.log(text);
  console.log('');
}

process.exit(0);
