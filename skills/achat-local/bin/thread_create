#!/usr/bin/env node
'use strict';

const fs = require('fs');
const path = require('path');
const os = require('os');
const crypto = require('crypto');
const { THREADS_DIR } = require(path.join(__dirname, '..', 'lib', 'platform'));

// Usage: thread_create [subject] [participant1] [participant2...]
const args = process.argv.slice(2);
const subject = args[0] || '';
const participants = args.slice(1);

const threadsDir = THREADS_DIR;
fs.mkdirSync(threadsDir, { recursive: true });

const threadId = crypto.randomUUID();
const contextId = crypto.randomUUID();
const createdAt = new Date().toISOString();

const header = {
  type: 'thread_header',
  thread_id: threadId,
  context_id: contextId,
  created_at: createdAt,
  participants: participants,
  subject: subject,
};

const filePath = path.join(threadsDir, `${threadId}.jsonl`);
fs.writeFileSync(filePath, JSON.stringify(header) + '\n', 'utf8');

console.log(`THREAD_ID: ${threadId}`);
process.exit(0);
