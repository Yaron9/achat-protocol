#!/usr/bin/env node
'use strict';

const fs = require('fs');
const path = require('path');
const os = require('os');
const crypto = require('crypto');
const { AGENTS_DIR, THREADS_DIR, requireYaml } = require(path.join(__dirname, '..', 'lib', 'platform'));
const yaml = requireYaml();

// Usage: thread_append <thread_id> <from> <to> <text> [intent=SAY]
const args = process.argv.slice(2);
if (args.length < 4) {
  console.error('Usage: thread_append <thread_id> <from> <to> <text> [intent=SAY]');
  process.exit(1);
}

const VALID_INTENTS = ['SAY', 'ASK', 'PROPOSE', 'DECIDE', 'DELEGATE', 'UPDATE', 'BLOCK'];

const [threadId, fromKey, toKey, ...textAndIntent] = args;
let intent = 'SAY';
let textParts = textAndIntent;
if (textAndIntent.length > 0 && VALID_INTENTS.includes(textAndIntent[textAndIntent.length - 1].toUpperCase())) {
  intent = textAndIntent[textAndIntent.length - 1].toUpperCase();
  textParts = textAndIntent.slice(0, -1);
}
const text = textParts.join(' ');

const threadsDir = THREADS_DIR;
const filePath = path.join(threadsDir, `${threadId}.jsonl`);

if (!fs.existsSync(filePath)) {
  console.error(`ERROR: Thread file not found: ${filePath}`);
  process.exit(1);
}

// Read existing lines to determine seq and contextId
const lines = fs.readFileSync(filePath, 'utf8').trim().split('\n').filter(l => l.trim());
// seq = number of message lines (excluding header)
const seq = lines.length; // header is line 0 (index 0), so messages start at seq=1

// Get contextId from header
let contextId = threadId; // fallback
try {
  const header = JSON.parse(lines[0]);
  if (header.context_id) contextId = header.context_id;
} catch (e) {
  // non-fatal
}

// Read sender's DID from agent.yaml
let fromDid = null;
const agentYamlPath = path.join(AGENTS_DIR, fromKey, 'agent.yaml');
if (fs.existsSync(agentYamlPath)) {
  try {
    const agentData = yaml.load(fs.readFileSync(agentYamlPath, 'utf8'));
    if (agentData.did && agentData.did !== 'null') {
      fromDid = agentData.did;
    }
  } catch (e) {
    // non-fatal
  }
}

// Attempt to sign
let signature = null;
let signedAt = null;
const ts = new Date().toISOString();
const keyFile = path.join(AGENTS_DIR, fromKey, 'key.json');
if (fs.existsSync(keyFile)) {
  try {
    const keyData = JSON.parse(fs.readFileSync(keyFile, 'utf8'));
    const privateKeyDer = Buffer.from(keyData.privateKey, 'base64');
    const privateKey = crypto.createPrivateKey({ key: privateKeyDer, format: 'der', type: 'pkcs8' });
    const signingPayload = `${fromKey}${toKey}${ts}${threadId}${text}`;
    const sig = crypto.sign(null, Buffer.from(signingPayload, 'utf8'), privateKey);
    signature = sig.toString('base64');
    signedAt = new Date().toISOString();
  } catch (e) {
    // non-fatal
  }
}

const message = {
  seq,
  type: 'message',
  role: 'user',
  from: fromKey,
  to: toKey,
  ts,
  contextId,
  parts: [{ kind: 'text', text }],
  metadata: {
    intent,
    visibility: 'private',
    version: '0.1.0',
    ...(fromDid ? { from_did: fromDid } : {}),
    subject: '',
    ...(signature ? { signature, signed_by: fromKey, signed_at: signedAt } : {}),
  },
};

fs.appendFileSync(filePath, JSON.stringify(message) + '\n', 'utf8');
console.log(`APPENDED seq=${seq} to thread ${threadId}`);
process.exit(0);
