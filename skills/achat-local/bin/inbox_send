#!/usr/bin/env node
'use strict';

const fs = require('fs');
const path = require('path');
const crypto = require('crypto');
const { execSync } = require('child_process');
const os = require('os');
const yaml = require('/Users/yaron/node_modules/js-yaml');

// Usage: node inbox_send <to_key> <from_key> <subject> <message_body> [intent]
const args = process.argv.slice(2);
if (args.length < 4) {
  console.error('Usage: node inbox_send <to_key> <from_key> <subject> <message_body> [intent]');
  process.exit(1);
}

const VALID_INTENTS = ['SAY', 'ASK', 'PROPOSE', 'DECIDE', 'DELEGATE', 'UPDATE', 'BLOCK'];

const [toKey, fromKey, subject, ...bodyAndIntent] = args;
// Last arg is intent if it matches a valid intent value
let intent = 'SAY';
let bodyParts = bodyAndIntent;
if (bodyAndIntent.length > 0 && VALID_INTENTS.includes(bodyAndIntent[bodyAndIntent.length - 1].toUpperCase())) {
  intent = bodyAndIntent[bodyAndIntent.length - 1].toUpperCase();
  bodyParts = bodyAndIntent.slice(0, -1);
}
const body = bodyParts.join(' ');

const inboxBase = path.join(os.homedir(), '.metame', 'memory', 'inbox');

// === Authorization Check ===
const agentYamlPath = path.join(os.homedir(), '.metame', 'agents', toKey, 'agent.yaml');
let authorizedSenders = []; // empty = open to all
if (fs.existsSync(agentYamlPath)) {
  try {
    const agentData = yaml.load(fs.readFileSync(agentYamlPath, 'utf8'));
    if (Array.isArray(agentData.authorized_senders) && agentData.authorized_senders.length > 0) {
      authorizedSenders = agentData.authorized_senders;
    }
  } catch (err) {
    // If yaml parse fails, treat as open (non-fatal)
    console.warn(`[achat-local] Could not parse agent.yaml for ${toKey}: ${err.message}`);
  }
}

if (authorizedSenders.length > 0 && !authorizedSenders.includes(fromKey)) {
  // Write to pending/ instead of inbox
  const pendingDir = path.join(inboxBase, toKey, 'pending');
  fs.mkdirSync(pendingDir, { recursive: true });

  const ts = new Date().toISOString();
  const threadId = crypto.randomUUID();
  const dateSlug = ts.replace(/[:.]/g, '-').slice(0, 19);
  const filename = `${dateSlug}_${fromKey}.md`;
  const pendingPath = path.join(pendingDir, filename);

  const pendingContent = [
    `FROM: ${fromKey}`,
    `TO: ${toKey}`,
    `TS: ${ts}`,
    `SUBJECT: ${subject}`,
    `THREAD_ID: ${threadId}`,
    `PSC_LEVEL: 0`,
    `X-ACHAT-INTENT: SAY`,
    `X-ACHAT-VISIBILITY: private`,
    `X-ACHAT-VERSION: 0.1.0`,
    `X-ACHAT-STATUS: pending`,
    '',
    body,
  ].join('\n');

  fs.writeFileSync(pendingPath, pendingContent, 'utf8');
  console.warn(`[achat-local] BLOCKED from=${fromKey} not in authorized_senders of ${toKey} → written to pending/`);
  process.exit(2);
}
// === End Authorization Check ===

const inboxDir = path.join(inboxBase, toKey);

// Ensure inbox directory exists
fs.mkdirSync(inboxDir, { recursive: true });

// Generate metadata
const ts = new Date().toISOString();
const threadId = crypto.randomUUID();
const dateSlug = ts.replace(/[:.]/g, '-').slice(0, 19);
const filename = `${dateSlug}_${fromKey}.md`;
const filepath = path.join(inboxDir, filename);

// Read sender's DID from agent.yaml if available
let fromDid = null;
const senderYaml = path.join(os.homedir(), '.metame', 'agents', fromKey, 'agent.yaml');
if (fs.existsSync(senderYaml)) {
  try {
    const yamlContent = fs.readFileSync(senderYaml, 'utf8');
    const didMatch = yamlContent.match(/^did:\s*(.+)$/m);
    if (didMatch && didMatch[1].trim() && didMatch[1].trim() !== 'null') {
      fromDid = didMatch[1].trim();
    }
  } catch (e) {
    // non-fatal
  }
}

// Build message file
const headers = [
  `FROM: ${fromKey}`,
  `TO: ${toKey}`,
  `TS: ${ts}`,
  `SUBJECT: ${subject}`,
  `THREAD_ID: ${threadId}`,
  `PSC_LEVEL: 0`,
  `X-ACHAT-INTENT: ${intent}`,
  `X-ACHAT-VISIBILITY: private`,
  `X-ACHAT-VERSION: 0.1.0`,
];
if (fromDid) {
  headers.push(`X-ACHAT-FROM-DID: ${fromDid}`);
}
headers.push('', body);

const content = headers.join('\n');

// Attempt to sign the message
let finalContent = content;
const keyFile = path.join(os.homedir(), '.metame', 'agents', fromKey, 'key.json');
if (fs.existsSync(keyFile)) {
  try {
    const keyData = JSON.parse(fs.readFileSync(keyFile, 'utf8'));
    const privateKeyDer = Buffer.from(keyData.privateKey, 'base64');
    const privateKey = crypto.createPrivateKey({ key: privateKeyDer, format: 'der', type: 'pkcs8' });

    // Canonical signing payload: FROM + TO + TS + THREAD_ID + body
    const signingPayload = `${fromKey}${toKey}${ts}${threadId}${body}`;
    const signature = crypto.sign(null, Buffer.from(signingPayload, 'utf8'), privateKey);
    const signatureBase64 = signature.toString('base64');
    const signedAt = new Date().toISOString();

    finalContent = content + '\n\n---\n' +
      `SIGNATURE: ${signatureBase64}\n` +
      `SIGNED_BY: ${fromKey}\n` +
      `SIGNED_AT: ${signedAt}`;
  } catch (err) {
    console.warn(`[achat-local] Signing skipped (error): ${err.message}`);
  }
} else {
  console.warn(`[achat-local] No key found for ${fromKey}, sending unsigned.`);
}

fs.writeFileSync(filepath, finalContent, 'utf8');
console.log(`[achat-local] Message written → ${filepath}`);

// === Thread Auto-Sync ===
{
  const threadsDir = path.join(os.homedir(), '.metame', 'memory', 'threads');
  fs.mkdirSync(threadsDir, { recursive: true });

  const threadFilePath = path.join(threadsDir, `${threadId}.jsonl`);

  // If thread file doesn't exist, create it (implicit thread_create)
  if (!fs.existsSync(threadFilePath)) {
    const contextId = crypto.randomUUID();
    const threadHeader = {
      type: 'thread_header',
      thread_id: threadId,
      context_id: contextId,
      created_at: ts,
      participants: [fromKey, toKey],
      subject: subject,
    };
    fs.writeFileSync(threadFilePath, JSON.stringify(threadHeader) + '\n', 'utf8');
  }

  // Read existing lines to determine seq and contextId
  const existingLines = fs.readFileSync(threadFilePath, 'utf8').trim().split('\n').filter(l => l.trim());
  const seq = existingLines.length; // header=line 0 counted, messages start at seq=1

  let contextId2 = threadId;
  try {
    const hdr = JSON.parse(existingLines[0]);
    if (hdr.context_id) contextId2 = hdr.context_id;
  } catch (e) { /* non-fatal */ }

  // Build signature info from finalContent if signed
  let msgSignature = null;
  let msgSignedAt = null;
  const sigMatch = finalContent.match(/^SIGNATURE: (.+)$/m);
  const sigAtMatch = finalContent.match(/^SIGNED_AT: (.+)$/m);
  if (sigMatch) msgSignature = sigMatch[1].trim();
  if (sigAtMatch) msgSignedAt = sigAtMatch[1].trim();

  const msgEntry = {
    seq,
    type: 'message',
    role: 'user',
    from: fromKey,
    to: toKey,
    ts,
    contextId: contextId2,
    parts: [{ kind: 'text', text: body }],
    metadata: {
      intent,
      visibility: 'private',
      version: '0.1.0',
      ...(fromDid ? { from_did: fromDid } : {}),
      subject,
      ...(msgSignature ? { signature: msgSignature, signed_by: fromKey, signed_at: msgSignedAt } : {}),
    },
  };

  fs.appendFileSync(threadFilePath, JSON.stringify(msgEntry) + '\n', 'utf8');
  console.log(`[achat-local] Thread synced → ${threadFilePath} (seq=${seq})`);
}
// === End Thread Auto-Sync ===

// Dispatch notification via MetaMe dispatch_to (best-effort)
try {
  const dispatchBin = path.join(os.homedir(), '.metame', 'bin', 'dispatch_to');
  execSync(`node ${dispatchBin} ${toKey} "📨 新消息来自 ${fromKey}: ${subject}" --from ${fromKey}`, {
    stdio: 'pipe',
    timeout: 5000,
  });
  console.log(`[achat-local] Notification dispatched → ${toKey}`);
} catch (err) {
  // dispatch_to may not be available in all environments; non-fatal
  console.warn(`[achat-local] dispatch_to skipped (not available or failed): ${err.message}`);
}

console.log(`[achat-local] SENT  from=${fromKey} to=${toKey} subject="${subject}" thread_id=${threadId}`);
